@Given("the {string} API is available")
public void theNamedApiIsAvailable(String serviceName) {
  ApiServiceSettings settings =
      EnvironmentContext.get().getApiServices().get(serviceName.toLowerCase());

  if (settings == null || settings.getBaseUrl() == null) {
    throw new IllegalStateException(
        "No apiServices entry found for '"
            + serviceName
            + "' in the active environment config. "
            + "Add it under 'apiServices' in your environment JSON file.");
  }

  baseUrlOverride = settings.getBaseUrl();
  log.info("'{}' API base URL: {}", serviceName, baseUrlOverride);
  ExtentReportManager.logInfo(serviceName + " API base URL: " + baseUrlOverride);
}
