  private void attachResponseToAllure(String method, String endpoint, Response response) {
    String body = response.getBody().asString();
    String summary =
        method + " " + endpoint + "\nHTTP " + response.getStatusCode()
            + " (" + response.getTime() + "ms)\n\n" + body;
