  private void assertSectionContains(JsonNode section, DataTable table) {
    Assert.assertNotNull(section, "Response section is missing");
    List<List<String>> comparison = new ArrayList<>();
    comparison.add(List.of("Field", "Expected", "Actual", "Result"));
    List<String> failures = new ArrayList<>();
    for (List<String> row : table.asLists(String.class)) {
      Assert.assertTrue(row.size() == 2, "Expected exactly 2 columns for key/value rows");
      String key = row.get(0);
      String expected = row.get(1);
      JsonNode actualNode = section.path(key);
      if (actualNode.isMissingNode()) {
        comparison.add(List.of(key, expected, "<missing>", "FAIL"));
        failures.add("Field '" + key + "' was not found in the response");
      } else {
        String actualText = actualNode.asText();
        boolean matches = jsonValueMatches(actualNode, expected);
        comparison.add(List.of(key, expected, actualText, matches ? "PASS" : "FAIL"));
        if (!matches) {
          failures.add("'" + key + "': expected '" + expected + "' but got '" + actualText + "'");
        }
      }
    }
    ExtentReportManager.logDataTable(comparison);
    if (!failures.isEmpty()) {
      AssertionError err =
          new AssertionError("Field assertion failures:\n" + String.join("\n", failures));
      ExtentReportManager.logFail("Assertion failures: " + String.join("; ", failures), err);
      throw err;
    }
  }
