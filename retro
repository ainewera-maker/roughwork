  @Given("the STP API is available")
  public void theStpApiIsAvailable() {
    ApiServiceSettings settings = EnvironmentContext.get().getApiServices().get("stp");
    if (settings == null || settings.getBaseUrl() == null) {
      throw new IllegalStateException(
          "No apiServices entry found for 'stp'. Add it under 'apiServices' in your environment"
              + " JSON.");
    }
    String baseUrl = settings.getBaseUrl();
    if (shouldUseStpMock(baseUrl)) {
      log.warn("STP host '{}' is not resolvable; falling back to embedded mock", baseUrl);
      theStpMockApiIsAvailable();
      return;
    }
    baseUrlOverride = baseUrl;
    String ntlmUser =
        System.getProperty(
            "stp.ntlm.username", System.getenv().getOrDefault("STP_NTLM_USERNAME", ""));
    String ntlmPass =
        System.getProperty(
            "stp.ntlm.password", System.getenv().getOrDefault("STP_NTLM_PASSWORD", ""));
    String ntlmDomain =
        System.getProperty(
            "stp.ntlm.domain", System.getenv().getOrDefault("STP_NTLM_DOMAIN", ""));
    String ntlmWs =
        System.getProperty(
            "stp.ntlm.workstation", System.getenv().getOrDefault("STP_NTLM_WORKSTATION", ""));
    stpClient = new RestAssuredClient(baseUrl);
    if (!ntlmUser.isBlank() && !ntlmPass.isBlank()) {
      stpClient.setNtlmAuth(ntlmUser, ntlmPass, ntlmWs, ntlmDomain);
      log.info("STP NTLM auth configured for user '{}'", ntlmUser);
      ExtentReportManager.logInfo("STP NTLM auth: " + ntlmUser + "@" + ntlmDomain);
    }
    log.info("STP real API base URL: {}", baseUrlOverride);
    ExtentReportManager.logInfo("STP API base URL: " + baseUrlOverride);
  }

  private boolean shouldUseStpMock(String baseUrl) {
    if (System.getProperty("stp.mock", "false").equalsIgnoreCase("true")) return true;
    try {
      URI uri = new URI(baseUrl);
      String host = uri.getHost();
      if (host == null) return true;
      InetAddress.getByName(host);
      return false;
    } catch (Exception e) {
      return true;
    }
  }
