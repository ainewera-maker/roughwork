@Given("the STP API is available")
public void theStpApiIsAvailable() {
  ApiServiceSettings settings =
      EnvironmentContext.get().getApiServices().get("stp");

  if (settings == null || settings.getBaseUrl() == null) {
    throw new IllegalStateException(
        "No apiServices entry found for 'stp' in the active environment config. "
            + "Add it under 'apiServices' in your environment JSON file.");
  }

  String baseUrl = settings.getBaseUrl();
  if (shouldUseStpMock(baseUrl)) {
    log.warn("STP host '{}' is not resolvable; falling back to embedded mock", baseUrl);
    theStpMockApiIsAvailable();
    return;
  }

  baseUrlOverride = baseUrl;
  log.info("STP real API base URL: {}", baseUrlOverride);
  ExtentReportManager.logInfo("STP API base URL: " + baseUrlOverride);
}

private boolean shouldUseStpMock(String baseUrl) {
  if (System.getProperty("stp.mock", "false").equalsIgnoreCase("true")) {
    return true;
  }
  try {
    URI uri = new URI(baseUrl);
    String host = uri.getHost();
    if (host == null) return true;
    InetAddress.getByName(host);
    return false;
  } catch (Exception e) {
    return true;
  }
}
