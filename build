#core-framework/src/main/java/com/smbc/raft/core/bdd/steps/ApiRequestSteps.java

@When("I send a {string} request to {string} with body from file {string}")
  public void iSendARequestToWithBodyFromFile(String method, String endpoint, String filePath) {
    String resolvedEndpoint = ctx.resolveVariables(endpoint);
    String body;
    try {
      body =
          new String(
              Thread.currentThread()
                  .getContextClassLoader()
                  .getResourceAsStream("testdata/" + filePath)
                  .readAllBytes());
    } catch (Exception e) {
      throw new IllegalStateException(
          "Could not load request body file 'testdata/" + filePath + "': " + e.getMessage(), e);
    }
    RestAssuredClient client =
        baseUrlOverride == null ? new RestAssuredClient() : new RestAssuredClient(baseUrlOverride);
    client.setContentType(io.restassured.http.ContentType.JSON);
    if (authToken != null && !authToken.isBlank()) {
      client.setHeader("Authorization", "Bearer " + authToken);
    }
    Response response = client.post(resolvedEndpoint, body);
    ctx.storeRawBody(response.getBody().asString());
    ctx.storeStatusCode(response.getStatusCode());
    ctx.storeResponseTimeMs(response.getTime());
    ApiLatencyCollector.record(method, resolvedEndpoint, response.getTime());
    ExtentReportManager.logInfo(
        method + " " + resolvedEndpoint + " → HTTP " + response.getStatusCode());
  }


